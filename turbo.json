{
	"$schema": "https://turborepo.com/schema.json",
	"tasks": {
		"dev": {
			"persistent": true,
			"cache": false
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"typecheck": {
			"dependsOn": ["^typecheck"]
		},
		"test": {
			"cache": false
		},
		"preview": {
			"dependsOn": ["build"],
			"persistent": true,
			"cache": false
		}
	}
}
